{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kdnsna/decklint/blob/main/schema/decklint-report-v1.schema.json",
  "title": "DeckLint Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "toolVersion", "profile", "file", "renderer", "scores", "summary", "findings", "slides"],
  "properties": {
    "schemaVersion": { "const": "decklint-report/v1" },
    "toolVersion": { "type": "string" },
    "profile": { "enum": ["baseline", "ai-generated"] },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sha256", "slides"],
      "properties": {
        "name": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "slides": { "type": "integer", "minimum": 0 }
      }
    },
    "renderer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested", "used", "status", "detail"],
      "properties": {
        "requested": { "enum": ["auto", "wireframe", "libreoffice"] },
        "used": { "enum": ["wireframe", "libreoffice"] },
        "status": { "enum": ["ok", "degraded"] },
        "detail": { "type": "string" }
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall", "categories", "weights", "policy", "deductions", "calculation"],
      "properties": {
        "overall": { "$ref": "#/$defs/score" },
        "categories": {
          "type": "object",
          "additionalProperties": false,
          "required": ["integrity", "readability", "editability", "consistency", "accessibility"],
          "properties": {
            "integrity": { "$ref": "#/$defs/score" },
            "readability": { "$ref": "#/$defs/score" },
            "editability": { "$ref": "#/$defs/score" },
            "consistency": { "$ref": "#/$defs/score" },
            "accessibility": { "$ref": "#/$defs/score" }
          }
        },
        "weights": {
          "type": "object",
          "additionalProperties": false,
          "required": ["integrity", "readability", "editability", "consistency", "accessibility"],
          "properties": {
            "integrity": { "type": "number", "const": 0.3 },
            "readability": { "type": "number", "const": 0.25 },
            "editability": { "type": "number", "const": 0.2 },
            "consistency": { "type": "number", "const": 0.15 },
            "accessibility": { "type": "number", "const": 0.1 }
          }
        },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["startingScore", "severityDeductions", "perRuleCap", "integrityCriticalOverallCap", "lowConfidenceAffectsScore", "privacyAffectsScore"],
          "properties": {
            "startingScore": { "const": 100 },
            "severityDeductions": {
              "type": "object",
              "additionalProperties": false,
              "required": ["critical", "high", "medium", "low"],
              "properties": {
                "critical": { "const": 30 },
                "high": { "const": 15 },
                "medium": { "const": 5 },
                "low": { "const": 1 }
              }
            },
            "perRuleCap": { "const": 30 },
            "integrityCriticalOverallCap": { "const": 49 },
            "lowConfidenceAffectsScore": { "const": false },
            "privacyAffectsScore": { "const": false }
          }
        },
        "deductions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["findingId", "category", "ruleId", "severity", "confidence", "requested", "applied", "reason"],
            "properties": {
              "findingId": { "type": "string" },
              "category": { "enum": ["integrity", "readability", "editability", "consistency", "accessibility", "privacy"] },
              "ruleId": { "type": "string" },
              "severity": { "enum": ["low", "medium", "high", "critical"] },
              "confidence": { "enum": ["low", "high"] },
              "requested": { "type": "integer", "minimum": 1, "maximum": 30 },
              "applied": { "type": "integer", "minimum": 0, "maximum": 30 },
              "reason": { "enum": ["applied", "low-confidence", "unscored-category", "per-rule-cap", "category-floor"] }
            }
          }
        },
        "calculation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method", "weightedTotal", "integrityCriticalCapApplied"],
          "properties": {
            "method": { "const": "weighted-average-rounded" },
            "weightedTotal": { "type": "number", "minimum": 0, "maximum": 100 },
            "integrityCriticalCapApplied": { "type": "boolean" }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical", "high", "medium", "low"],
      "properties": {
        "critical": { "type": "integer", "minimum": 0 },
        "high": { "type": "integer", "minimum": 0 },
        "medium": { "type": "integer", "minimum": 0 },
        "low": { "type": "integer", "minimum": 0 }
      }
    },
    "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
    "slides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "title", "preview"],
        "properties": {
          "index": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "titleSource": { "enum": ["placeholder", "inferred", "none"] },
          "preview": { "type": "string", "pattern": "^(data:image/png;base64,|$)" }
        }
      }
    }
  },
  "$defs": {
    "score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "bbox": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "w": { "type": "number", "minimum": 0 },
        "h": { "type": "number", "minimum": 0 }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule_id", "category", "severity", "confidence", "message", "evidence", "remediation", "slide_index", "shape_id", "bbox"],
      "properties": {
        "id": { "type": "string" },
        "rule_id": { "type": "string" },
        "category": { "enum": ["integrity", "readability", "editability", "consistency", "accessibility", "privacy"] },
        "severity": { "enum": ["low", "medium", "high", "critical"] },
        "confidence": { "enum": ["low", "high"] },
        "message": { "type": "string" },
        "evidence": { "type": "string" },
        "remediation": { "type": "string" },
        "slide_index": { "type": ["integer", "null"], "minimum": 1 },
        "shape_id": { "type": ["string", "null"] },
        "bbox": { "$ref": "#/$defs/bbox" }
      }
    }
  }
}
